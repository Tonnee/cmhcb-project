datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Therapist {
  id         String   @id
  image      String
  name       String
  role       String
  bio        String
  education  String   // JSON string of string[]
  training   String   // JSON string of string[]
  expertise  String   // JSON string of string[]
  experience String   // JSON string of string[]
  fees       String   // JSON string of fee categories
  services   String   // JSON string of string[]
  activities String   // JSON string of string[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastUpdatedBy String?
}

model Workshop {
  id          String   @id
  slug        String   @unique
  title       String
  description String
  image       String
  date        String
  time        String
  location    String
  author      String
  tags        String   // JSON string of string[]
  isFeatured  Boolean  @default(false)
  content     String?
  gallery     String?  // JSON string of string[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastUpdatedBy String?
}

model BlogPost {
  id          String   @id
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  image       String
  publishedAt String
  author      String
  tags        String   // JSON string of string[]
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastUpdatedBy String?
}

model Testimonial {
  id         String   @id
  name       String
  role       String
  avatar     String
  quote      String
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LandingPageContent {
  id                  String   @id @default("landing-content")
  heroHeadline        String
  heroSubtitle        String
  heroBgImage         String   @default("/hero-image/hero-bg.png")
  heroFigureImage     String   @default("/hero-image/hero-figure.png")
  wellbeingHeadline   String
  wellbeingSubtitle   String
  experienceCount     Int      @default(20)
  happyClientsCount   Int      @default(1500)
  sessionsCount       Int      @default(2800)
  satisfactionRate    Int      @default(94)
  trainingHeadline    String   @default("Want to Make a <span class=\"text-primary-dark\">Difference</span> in <span class=\"text-accent\">Mental Health</span>?")
  trainingSubtitle    String   @default("Our specialized trainings equip professionals, educators, and caregivers with the tools needed to foster mental well-being in their communities.")
  trainingImage       String   @default("/mental-health-training-program.png")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastUpdatedBy String?
}

model Service {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  icon             String
  shortDescription String
  longDescription  String
  approach         String
  isFeatured       Boolean  @default(false)
  showInNavbar     Boolean  @default(true)
  image            String?
  bgImage          String?
  duration         String?
  fees             String?
  whoIsItFor       String?
  format           String?
  language         String?
  faqs             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastUpdatedBy String?
}

model ServiceInfoBlock {
  id        String   @id @default(cuid())
  heading   String
  items     String   // JSON string of string[] (bullet items)
  ctaLabel  String
  ctaHref   String
  image     String
  imageAlt  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastUpdatedBy String?
}

model TrainingInfoBlock {
  id            String   @id @default(cuid())
  heading       String
  items         String   // JSON string of string[] (bullet items)
  ctaLabel      String
  ctaHref       String
  image         String
  imageAlt      String
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastUpdatedBy String?
}

model AdminProfile {
  id           String        @id
  email        String        @unique
  name         String
  role         String        @default("admin") // "admin" or "super_admin"
  isBlocked    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]
}

model ActivityLog {
  id          String       @id @default(cuid())
  adminId     String
  adminEmail  String
  adminName   String
  action      String       // "CREATE", "UPDATE", "DELETE", "BLOCK", "UNBLOCK", "UPDATE_PASSWORD", "CREATE_ADMIN", etc.
  targetType  String       // "BlogPost", "Service", "Therapist", "Workshop", "LandingPageContent", "AdminProfile"
  targetId    String
  targetName  String
  details     String?      // JSON string of change details or comments
  createdAt   DateTime     @default(now())
  admin       AdminProfile @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Training {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  heroTitle        String
  heroDescription  String
  introTitle       String
  introDescription String
  sections         String   // JSON string of { title: string, items: string[] }[]
  faq              String   // JSON string of { question: string, answer: string }[]
  features         String   // JSON string of string[]
  duration         String
  fees             String
  variant          String   @default("primary")
  image            String?
  bgImage          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastUpdatedBy    String?
}

model AboutPageContent {
  id              String   @id @default("about-content")
  heroTitle       String   @default("Dedicated to Your Mental Well-being")
  heroDescription String   @default("The Center for Mental Health and Care Bangladesh (CMHCB) is a leading institution committed to providing accessible, compassionate, and high-quality psychological support to individuals and families across the nation.")
  heroImage       String   @default("/hero-image/psychotherapy-counseling-session.png")
  missionTitle    String   @default("Our Mission")
  missionText     String   @default("To provide accessible, compassionate, and evidence-based mental health care to individuals and communities across Bangladesh.")
  visionTitle     String   @default("Our Vision")
  visionText      String   @default("A Bangladesh where mental health is understood, valued, and prioritized as an essential component of overall well-being.")
  coreValues      String   @default("[]") // JSON: { title, description, icon }[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastUpdatedBy   String?
}

model ContactPageContent {
  id            String   @id @default("contact-content")
  phone         String   @default("+880 1974-349569")
  email         String   @default("info@cmhcbd.com")
  addressLine1  String   @default("CMHC Office Room, 78/2 (2nd Floor)")
  addressLine2  String   @default("New Airport Road, Tejkunipara")
  addressLine3  String   @default("Tejgoan, Dhaka-1212")
  facebookUrl   String   @default("#")
  instagramUrl  String   @default("#")
  twitterUrl    String   @default("#")
  linkedinUrl   String   @default("#")
  mapEmbedUrl   String   @default("https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3651.810573934375!2d90.3907579!3d23.7541819!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3755c7793b5847e7%3A0xa64aa8a96677f40d!2sTejgaon%2C%20Dhaka!5e0!3m2!1sen!2sbd!4v1689200000000!5m2!1sen!2sbd")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastUpdatedBy String?
}

model FaqPageContent {
  id          String   @id @default("faq-content")
  heroTitle   String   @default("We are here to answer your questions")
  heroDescription String @default("Whether you're new to therapy or an existing client, we've compiled a list of common questions to help you understand our services, payment methods, and privacy policies.")
  heroImage   String   @default("/understanding-anxiety-workshop-event.png")
  items       String   @default("[]") // JSON: { category, question, answer }[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastUpdatedBy String?
}

model PolicyPageContent {
  id            String   @id // "privacy-policy" | "terms"
  title         String
  subtitle      String   @default("Last Updated: May 2026")
  content       String   // plain text / HTML
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastUpdatedBy String?
}

model AffiliationPageContent {
  id              String   @id @default("affiliation-content")
  heroTitle       String   @default("Partner with CMHCB")
  heroDescription String   @default("Join our network of professionals and organizations dedicated to advancing mental health care in Bangladesh. Together, we can make a greater impact by expanding access to quality psychological support.")
  heroImage       String   @default("/hero-image/psychotherapy-counseling-session.png")
  partners        String   @default("[]") // JSON: { name, type, abbr }[]
  benefits        String   @default("[]") // JSON: { title, description, icon }[]
  ctaTitle        String   @default("Let's shape the future of mental health together")
  ctaDescription  String   @default("Join hands with CMHCB to foster clinical excellence, expand counseling accessibility, and build a stronger mental health support ecosystem across Bangladesh.")
  promises        String   @default("[]") // JSON string of string[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastUpdatedBy   String?
}

model SupportPageContent {
  id              String   @id @default("support-content")
  heroTitle       String   @default("We are here to support you in times of need")
  heroDescription String   @default("Whether you are facing a mental health crisis or seeking guidance for a loved one, CMHCB is here to help. Reach out to our emergency contacts or trained professionals for immediate assistance.")
  heroImage       String   @default("/hero-image/group-therapy-support-circle.png")
  contacts        String   @default("[]") // JSON: { title, description, phone, hours, iconName, isPrimary }[]
  advisoryText    String   @default("Important Advisory: CMHCB and associated emotional helper helplines provide psychological support, mental health counseling, and crisis triage. If you or someone you know is in immediate physical danger, experiencing a severe drug/medical emergency, or threatened by active self-harm, please dial the National Emergency Hotline (999) or proceed immediately to the nearest hospital emergency department.")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastUpdatedBy   String?
}

model CommunityServicePageContent {
  id                     String   @id @default("community-service-content")
  heroTitle              String   @default("Community Service Policy & Outreach")
  heroSubtitle           String   @default("Last Updated: May 2026")
  heroDescription        String   @default("At the Center for Mental Health and Care Bangladesh (CMHCB), we believe mental health support is a human right. Explore our structured community-oriented programs and the ethical guidelines that define our outreach initiatives.")
  introTitle             String   @default("Our Commitment to Bangladesh's Communities")
  introDescription1      String   @default("CMHCB dedicates a portion of its resources and clinical hours to pro-bono work, local community workshops, and disaster response. Through structured partnerships, we aim to bridge the mental health service gap in Bangladesh.")
  introDescription2      String   @default("Our practitioners actively volunteer to implement community support initiatives, adhering to the same high ethical standards, confidentiality, and professional competence required in our standard clinical practices.")
  stats                  String   @default("[]") // JSON: { value, title, description }[]
  pillars                String   @default("[]") // JSON: { badge, title, description, iconName }[]
  eligibilityTitle       String   @default("Eligibility & Verification")
  eligibilityDescription String   @default("To ensure that our community and pro-bono services reach the individuals who need them most, we maintain a clear verification framework. Services are allocated based on these parameters:")
  eligibilityItems       String   @default("[]") // JSON: { title, description }[]
  guidelinesTitle        String   @default("Operational Guidelines")
  guidelinesDescription  String   @default("CMHCB maintains strong professional boundaries in its volunteer and outreach services to guarantee safety, quality, and clinical ethics.")
  guidelinesItems        String   @default("[]") // JSON: { title, description }[]
  ctaTitle               String   @default("Request a Community Outreach Session")
  ctaDescription         String   @default("Are you an NGO, school, university, or local community leader looking to partner with CMHCB for mental health awareness training or counseling camps? Write to our coordinator today.")
  ctaEmail               String   @default("outreach@cmhcbd.com")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  lastUpdatedBy          String?
}

model GalleryItem {
  id           String   @id @default(cuid())
  type         String   @default("image") // "image" | "video"
  src          String
  thumbnailSrc String?
  alt          String
  caption      String
  category     String   // "event" | "workshop" | "activity" | "occasion"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastUpdatedBy String?
}

